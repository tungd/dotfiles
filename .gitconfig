[user]
  name = Tung Dao
  email = me@tungdao.com
  signingkey = me@tungdao.com
[alias]
  cl = clone
  co = checkout
  st = status -sb
  ci = commit
  br = branch
  ls = log --graph --decorate --oneline
  lsh = log --oneline --stat --decorate
  conflicts = diff --name-only --diff-filter=U
  amend = commit --amend --reuse-message=HEAD
  undo = reset --soft HEAD^
  df = diff
  dfc = diff --cached
  td = commit --amend --author='TD <t.d@revenge.games>' --no-edit
[url "git@github.com:"]
  insteadOf = gh:
[push]
	default = simple
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[commit]
  gpgsign = true
[init]
  defaultBranch = main
[pull]
  ff = only
[url "git@github-rg:Revenge-Games/"]
	insteadOf = https://github.com/Revenge-Games/
[includeIf "gitdir:/Users/tung/Projects/BlackWhite-Games/"]
	path = ~/.gitconfig-revenge
[credential "https://github.com"]
	helper = 
	helper = !/opt/local/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/local/bin/gh auth git-credential
