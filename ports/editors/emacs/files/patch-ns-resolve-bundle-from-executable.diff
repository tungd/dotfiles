+#ifdef NS_IMPL_COCOA
+static NSString *
+ns_bundle_path_from_executable (void)
+/* Return the containing .app bundle path based on the real executable.
+
+   NSBundle's main bundle is not reliable when Contents/MacOS/Emacs is
+   invoked through a symlink outside Emacs.app.  Resolve the executable path
+   so symlinked command-line launchers still find bundled resources.  */
+{
+  uint32_t size = 0;
+
+  if (_NSGetExecutablePath (NULL, &size) != -1 || size == 0)
+    return nil;
+
+  char *path = malloc (size);
+  if (!path)
+    return nil;
 
+  NSString *bundle_path = nil;
 
+  if (_NSGetExecutablePath (path, &size) == 0)
+    {
+      char *resolved = realpath (path, NULL);
+      const char *executable = resolved ? resolved : path;
+      NSString *executable_path = [NSString stringWithUTF8String:executable];
+
+      if (executable_path)
+        {
+          NSString *macos_path = [executable_path stringByDeletingLastPathComponent];
+          NSString *contents_path = [macos_path stringByDeletingLastPathComponent];
+          NSString *candidate = [contents_path stringByDeletingLastPathComponent];
+
+          if ([[macos_path lastPathComponent] isEqualToString:@"MacOS"]
+              && [[contents_path lastPathComponent] isEqualToString:@"Contents"]
+              && [[candidate pathExtension] isEqualToString:@"app"])
+            bundle_path = candidate;
+        }
+
+      free (resolved);
+    }
+
+  free (path);
+  return bundle_path;
+}
+#endif
